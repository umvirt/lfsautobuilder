. env.sh

if [ "$USER" != "root" ] ; then 
echo "WRONG USER"

exit
fi

date +%s > log/autobuild.start

for s in `cat vmcmds.txt` ; do


echo "Running: $s"

sleep 1

date +%s > log/_$s.start

echo $s > log/current_autoscript

./$s 2>&1 | tee log/_$s.log

date +%s > log/_$s.end

if [ -f log/partition.lock ]
then

echo "Error: Target partiton not found!"

rm log/partition.lock

exit

fi

done

date +%s > log/autobuild.end

#mount partition
mount -v $LFS_PARTITION builddir

#copy build log
mkdir -p builddir/var/log/lfsautobuilder
cp -rv log/* builddir/var/log/lfsautobuilder

#umount partition
umount -v $LFS_PARTITION
