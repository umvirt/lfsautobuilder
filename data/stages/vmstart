. env.sh

#create lockfle
touch log/partition.lock

#if partiton exists
if [ -b  $LFS_PARTITION ]
then

if [[ "$LFS_FORMAT_PARTITION" == "YES" ]]
then


echo "Formatting partition: $LFS_PARTITION"
echo ""
echo "Formatting will be started at 10 seconds..."
echo "It will destroy all data. Press Ctrl+C to cancel."
echo ""
sleep 10

#formating
mkfs.ext4 -F $LFS_PARTITION

fi

#mounting
mount $LFS_PARTITION builddir &&

#delete lockfile
rm log/partition.lock

fi