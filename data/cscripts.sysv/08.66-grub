. /cscripts/env.sh

cd /sources

tar -xf grub-2.14.tar.xz

cd grub-2.14

unset {C,CPP,CXX,LD}FLAGS

sed 's/--image-base/--nonexist-linker-option/' -i configure

./configure --prefix=/usr     \
            --sysconfdir=/etc \
            --disable-efiemu  \
            --disable-werror

make

make install
