. /cscripts/env.sh

cd /sources

tar -xf libxcrypt-4.5.2.tar.xz

cd libxcrypt-4.5.2

sed -i '/strchr/s/const//' lib/crypt-{sm3,gost}-yescrypt.c


./configure --prefix=/usr                \
            --enable-hashes=strong,glibc \
            --enable-obsolete-api=no     \
            --disable-static             \
            --disable-failure-tokens

make

if [[ "$ULFS_TESTS" == "YES" ]]
then

make check

fi


make install
